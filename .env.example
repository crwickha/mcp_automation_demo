# ============================================
# Meraki API Configuration
# ============================================

# Required: Your Meraki Dashboard API Key
# Get it from: https://dashboard.meraki.com -> Organization -> Settings -> API access
MERAKI_API_KEY=your-meraki-api-key-here

# Required: Your Meraki Organization ID
MERAKI_ORG_ID=your-org-id-here

# ============================================
# Cloudflare Tunnel Configuration
# ============================================

# Required: Your Cloudflare Tunnel token
# Create a tunnel at: https://one.dash.cloudflare.com -> Networks -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
